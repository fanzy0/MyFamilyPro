#### 3. 创建Mapper接口（位置: paxl/mapper/）
```java
package com.my.family.paxl.mapper;

import com.baomidou.mybatisplus.core.mapper.BaseMapper;
import com.my.family.paxl.domain.entity.UserDO;
import org.apache.ibatis.annotations.Mapper;
import org.apache.ibatis.annotations.Param;

import java.util.List;

/**
 * 用户Mapper接口
 *
 * @author ai
 * @date 2026/02/28
 */
@Mapper
public interface UserMapper extends BaseMapper<UserDO> {

    /**
     * 根据用户名模糊查询
     *
     * @param userName 用户名
     * @return 用户列表
     */
    List<UserDO> selectByUserNameLike(@Param("userName") String userName);
}
```

#### 4. 创建Mapper XML（位置: paxl/resources/mapper/）
**注意：必须使用MySQL语法和动态SQL**

```xml
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.my.family.paxl.mapper.UserMapper">

    <!-- 基础结果映射 -->
    <resultMap id="BaseResultMap" type="com.my.family.paxl.domain.entity.UserDO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="user_name" property="userName"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 根据用户名模糊查询 -->
    <select id="selectByUserNameLike" resultMap="BaseResultMap">
        SELECT id, user_id, user_name, create_time, update_time
        FROM t_user
        WHERE user_name LIKE CONCAT('%', #{userName}, '%')
        ORDER BY create_time DESC
    </select>

</mapper>
```

**动态SQL示例**：
```xml
<!-- 动态条件查询 -->
<select id="selectByCondition" resultMap="BaseResultMap">
    SELECT * FROM t_user
    <where>
        <if test="userName != null and userName != ''">
            AND user_name LIKE CONCAT('%', #{userName}, '%')
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
    </where>
    ORDER BY create_time DESC
    <if test="limit != null and limit > 0">
        LIMIT #{limit} OFFSET #{offset}
    </if>
</select>
```

#### 5. 创建Service（位置: paxl/service/和paxl/service/impl/）

**Service接口：**
```java
package com.my.family.paxl.service;

import com.my.family.paxl.domain.entity.UserDO;
import java.util.List;

/**
 * 用户服务接口
 *
 * @author ai
 * @date 2026/02/28
 */
public interface UserService {

    /**
     * 根据用户名查询用户
     *
     * @param userName 用户名
     * @return 用户列表
     */
    List<UserDO> queryByUserName(String userName);

    /**
     * 保存用户
     *
     * @param userDO 用户对象
     * @return 保存后的用户对象
     */
    UserDO saveUser(UserDO userDO);
}
```

**Service实现：**
```java
package com.my.family.paxl.service.impl;

import com.my.family.paxl.domain.entity.UserDO;
import com.my.family.paxl.mapper.UserMapper;
import com.my.family.paxl.service.UserService;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.List;

/**
 * 用户服务实现
 *
 * @author ai
 * @date 2026/02/28
 */
@Service
@Slf4j
public class UserServiceImpl implements UserService {

    private final UserMapper userMapper;

    public UserServiceImpl(UserMapper userMapper) {
        this.userMapper = userMapper;
    }

    @Override
    public List<UserDO> queryByUserName(String userName) {
        log.info("[QueryByUserName] 开始查询, userName={}", userName);
        List<UserDO> users = userMapper.selectByUserNameLike(userName);
        log.info("[QueryByUserName] 查询完成, count={}", users.size());
        return users;
    }

    @Override
    @Transactional(rollbackFor = Exception.class)
    public UserDO saveUser(UserDO userDO) {
        log.info("[SaveUser] 开始保存用户, userName={}", userDO.getUserName());
        userMapper.insert(userDO);
        log.info("[SaveUser] 保存成功, userId={}", userDO.getUserId());
        return userDO;
    }
}
```

#### 6. 创建Controller（位置: paxl/controller/）
```java
package com.my.family.paxl.controller;

import com.my.family.paxl.domain.entity.UserDO;
import com.my.family.paxl.service.UserService;
import lombok.extern.slf4j.Slf4j;
import org.springframework.http.ResponseEntity;
import org.springframework.util.StringUtils;
import org.springframework.web.bind.annotation.*;

import java.util.List;

/**
 * 用户控制器
 *
 * @author ai
 * @date 2026/02/28
 */
@RestController
@RequestMapping("/api/user")
@Slf4j
public class UserController {

    private final UserService userService;

    public UserController(UserService userService) {
        this.userService = userService;
    }

    /**
     * 查询用户列表
     *
     * @param userName 用户名（可选）
     * @return 用户列表
     */
    @GetMapping("/list")
    public ResponseEntity<List<UserDO>> listUsers(@RequestParam(required = false) String userName) {
        try {
            log.info("[ListUsers] 开始查询, userName={}", userName);
            List<UserDO> users = userService.queryByUserName(userName);
            log.info("[ListUsers] 查询成功, count={}", users.size());
            return ResponseEntity.ok(users);

        } catch (Exception e) {
            log.error("[ListUsers] 查询用户列表异常, userName={}", userName, e);
            return ResponseEntity.internalServerError().build();
        }
    }

    /**
     * 保存用户
     *
     * @param userDO 用户对象
     * @return 操作结果
     */
    @PostMapping("/save")
    public ResponseEntity<String> saveUser(@RequestBody UserDO userDO) {
        try {
            if (userDO == null) {
                return ResponseEntity.badRequest().body("用户信息不能为空");
            }
            if (!StringUtils.hasText(userDO.getUserName())) {
                return ResponseEntity.badRequest().body("用户名不能为空");
            }

            UserDO savedUser = userService.saveUser(userDO);
            log.info("[SaveUser] 保存成功, userId={}", savedUser.getUserId());
            return ResponseEntity.ok("保存成功");

        } catch (IllegalArgumentException e) {
            log.warn("[SaveUser] 参数校验失败, msg={}", e.getMessage());
            return ResponseEntity.badRequest().body(e.getMessage());
        } catch (Exception e) {
            log.error("[SaveUser] 保存用户异常", e);
            return ResponseEntity.internalServerError().body("保存失败: " + e.getMessage());
        }
    }
}
```

