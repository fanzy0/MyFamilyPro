<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.my.family.paxl.mapper.BannerMapper">

    <!--
      轮播图片表映射配置
      数据库表：t_banner
    -->
    <resultMap id="BannerResultMap" type="com.my.family.paxl.domain.entity.BannerDO">
        <id column="id" property="id"/>
        <result column="banner_id"   property="bannerId"/>
        <result column="family_id"   property="familyId"/>
        <result column="image_path"  property="imagePath"/>
        <result column="position"    property="position"/>
        <result column="title"       property="title"/>
        <result column="description" property="description"/>
        <result column="link_url"    property="linkUrl"/>
        <result column="status"      property="status"/>
        <result column="deleted"     property="deleted"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!--
      通用查询字段
    -->
    <sql id="Base_Column_List">
        id, banner_id, family_id, image_path, position, title, description, link_url, status, deleted, create_time, update_time
    </sql>

    <!--
      新增轮播图片
    -->
    <insert id="insert" parameterType="com.my.family.paxl.domain.entity.BannerDO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_banner (
            banner_id, family_id, image_path, position, title, description, link_url, status, deleted, create_time, update_time
        ) VALUES (
            #{bannerId}, #{familyId}, #{imagePath}, #{position}, #{title}, #{description}, #{linkUrl}, #{status}, #{deleted}, #{createTime}, #{updateTime}
        )
    </insert>

    <!--
      根据主键ID更新轮播图片信息
    -->
    <update id="updateById" parameterType="com.my.family.paxl.domain.entity.BannerDO">
        UPDATE t_banner
        <set>
            <if test="bannerId != null">
                banner_id = #{bannerId},
            </if>
            <if test="imagePath != null and imagePath != ''">
                image_path = #{imagePath},
            </if>
            <if test="position != null">
                position = #{position},
            </if>
            <if test="title != null">
                title = #{title},
            </if>
            <if test="description != null">
                description = #{description},
            </if>
            <if test="linkUrl != null">
                link_url = #{linkUrl},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="deleted != null">
                deleted = #{deleted},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime}
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM t_banner
        WHERE id = #{id}
    </delete>

    <!--
      根据轮播图ID（业务编号）查询轮播图片信息
    -->
    <select id="selectByBannerId" parameterType="java.lang.Long" resultMap="BannerResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM t_banner
        WHERE banner_id = #{bannerId}
        AND deleted = 0
        LIMIT 1
    </select>

    <!--
      查询当前未删除轮播图中最大的轮播图ID（banner_id）
    -->
    <select id="selectMaxBannerId" resultType="java.lang.Long">
        SELECT MAX(banner_id)
        FROM t_banner
        WHERE deleted = 0
    </select>

    <!--
      查询指定家庭下所有启用的轮播图片，按位置排序
    -->
    <select id="selectEnabledBanners" resultMap="BannerResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM t_banner
        WHERE family_id = #{familyId}
          AND status = 1
          AND deleted = 0
        ORDER BY position ASC, create_time DESC
    </select>


</mapper>

