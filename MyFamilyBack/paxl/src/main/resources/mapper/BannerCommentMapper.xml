<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.my.family.paxl.mapper.BannerCommentMapper">

    <!--
      轮播图评论表映射配置
      数据库表：t_banner_comment
    -->
    <resultMap id="BannerCommentResultMap" type="com.my.family.paxl.domain.entity.BannerCommentDO">
        <id column="id" property="id"/>
        <result column="comment_id" property="commentId"/>
        <result column="banner_id" property="bannerId"/>
        <result column="user_name" property="userName"/>
        <result column="content" property="content"/>
        <result column="status" property="status"/>
        <result column="deleted" property="deleted"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!--
      通用查询字段
    -->
    <sql id="Base_Column_List">
        id, comment_id, banner_id, user_name, content, status, deleted, create_time, update_time
    </sql>

    <!--
      新增评论
    -->
    <insert id="insert" parameterType="com.my.family.paxl.domain.entity.BannerCommentDO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_banner_comment (
            comment_id, banner_id, user_name, content, status, deleted, create_time, update_time
        ) VALUES (
            #{commentId}, #{bannerId}, #{userName}, #{content}, #{status}, #{deleted}, #{createTime}, #{updateTime}
        )
    </insert>

    <!--
      根据轮播图ID查询评论列表
    -->
    <select id="selectByBannerId" parameterType="java.lang.Long" resultMap="BannerCommentResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM t_banner_comment
        WHERE banner_id = #{bannerId}
        AND deleted = 0
        ORDER BY create_time DESC
    </select>

    <!--
      查询当前未删除评论中最大的评论ID（comment_id）
    -->
    <select id="selectMaxCommentId" resultType="java.lang.Long">
        SELECT MAX(comment_id)
        FROM t_banner_comment
        WHERE deleted = 0
    </select>

    <!--
      根据主键ID逻辑删除评论
    -->
    <update id="deleteById" parameterType="java.lang.Long">
        UPDATE t_banner_comment
        SET deleted = 1, update_time = NOW()
        WHERE id = #{id}
    </update>

</mapper>

