<!--pages/login/login.wxml-->
<view class="container">

  <!-- 自动登录校验中的 loading 遮罩 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <!-- 网络降级兜底：仅在临时登录也失败时展示 -->
  <view class="login-body" wx:if="{{!loading}}">

    <!-- Logo 与标题区域 -->
    <view class="logo-section">
      <view class="logo-circle">
        <text class="logo-text">家</text>
      </view>
      <text class="app-name">清居叙暖</text>
      <text class="app-slogan">积善之家，必有余庆</text>
    </view>

    <!-- 功能简介 -->
    <view class="features-section">
      <view class="feature-item">
        <text class="feature-icon">📅</text>
        <text class="feature-desc">重要事件到期提醒</text>
      </view>
      <view class="feature-item">
        <text class="feature-icon">👨‍👩‍👧‍👦</text>
        <text class="feature-desc">记录家庭美好瞬间</text>
      </view>
    </view>

    <!-- 登录按钮区域（仅网络故障降级时展示） -->
    <view class="login-section">

      <!-- 协议勾选 -->
      <view class="agreement-wrap" bindtap="onToggleAgreement">
        <view class="checkbox {{agreed ? 'checkbox-checked' : ''}}">
          <text class="checkbox-icon" wx:if="{{agreed}}">✓</text>
        </view>
        <view class="agreement-text">
          <text class="agreement-prefix">我已阅读并同意</text>
          <text
            class="agreement-link"
            catchtap="onViewProtocol"
            data-type="USER_PROTOCOL"
          >《用户协议》</text>
          <text class="agreement-prefix">和</text>
          <text
            class="agreement-link"
            catchtap="onViewProtocol"
            data-type="PRIVACY_STATEMENT"
          >《隐私声明》</text>
        </view>
      </view>

      <button
        class="login-btn {{loginLoading ? 'login-btn-loading' : ''}} {{!agreed ? 'login-btn-disabled' : ''}}"
        bindtap="onLoginTap"
        disabled="{{loginLoading || !agreed}}"
      >
        <view class="btn-content">
          <text class="btn-text">{{loginLoading ? '登录中...' : '微信一键登录'}}</text>
        </view>
      </button>

    </view>

  </view>

</view>
