/* pages/login/login.wxss */

page {
  background: linear-gradient(160deg, #b8d4e8 0%, #d8e8f0 40%, #e8f4fd 100%);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 60rpx;
  box-sizing: border-box;
}

/* loading 遮罩 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #b8d4e8 0%, #d8e8f0 40%, #e8f4fd 100%);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  border-top-color: #5a9fd4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #5a6c7d;
}

/* 登录主体 */
.login-body {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5eb8ff 0%, #4facfe 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(79, 172, 254, 0.4);
  margin-bottom: 32rpx;
}

.logo-text {
  font-size: 80rpx;
  color: #fff;
  font-weight: bold;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.app-name {
  font-size: 52rpx;
  font-weight: bold;
  color: #2c3e50;
  letter-spacing: 6rpx;
  margin-bottom: 16rpx;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.app-slogan {
  font-size: 26rpx;
  color: #7f8fa6;
  letter-spacing: 2rpx;
}

/* 功能简介 */
.features-section {
  width: 100%;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 24rpx;
  padding: 40rpx 48rpx;
  box-sizing: border-box;
  margin-bottom: 72rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.feature-item {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.feature-item:last-child {
  margin-bottom: 0;
}

.feature-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  line-height: 1;
}

.feature-desc {
  font-size: 28rpx;
  color: #4a5568;
  line-height: 1.5;
}

/* 登录按钮区域 */
.login-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.35);
  margin-bottom: 28rpx;
  padding: 0;
}

.login-btn::after {
  border: none;
}

.login-btn-loading {
  background: linear-gradient(135deg, #94d3b0 0%, #87c5a3 100%);
  box-shadow: none;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.wechat-icon {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-right: 12rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2rpx;
}

.login-tips {
  font-size: 22rpx;
  color: #a0aec0;
  text-align: center;
  line-height: 1.6;
}
