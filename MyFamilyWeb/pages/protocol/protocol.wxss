/* pages/protocol/protocol.wxss */

.container {
  min-height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 16rpx;
  padding-right: 16rpx;
  padding-bottom: 16rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 52rpx;
  color: #333;
  font-weight: 300;
  line-height: 1;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
  text-align: center;
}

.nav-placeholder {
  width: 80rpx;
}

/* 加载状态 */
.loading-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #4a90d9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载失败 */
.error-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 60rpx;
}

.error-icon {
  font-size: 80rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

.retry-btn {
  margin-top: 20rpx;
  padding: 18rpx 60rpx;
  background: #4a90d9;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* 内容区域 */
.content-scroll {
  flex: 1;
  height: 0;
}

.content-body {
  padding: 40rpx 36rpx 80rpx;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.9;
  white-space: pre-wrap;
  word-break: break-word;
}
