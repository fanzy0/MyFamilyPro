/* pages/event/list/list.wxss */

page {
  background: #f0f4f8;
  min-height: 100vh;
  width: 100%;
}

.container {
  min-height: 100vh;
  width: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* ============================
   顶部区域 — 渐变背景
   ============================ */
.header {
  width: 100%;
  background: linear-gradient(160deg, #1a7ff0 0%, #4facfe 65%, #87c3ff 100%);
  padding-bottom: 0;
  flex-shrink: 0;
  box-sizing: border-box;
  padding-top: 15px;
  padding-bottom: 15rpx;
}

/* 第一行：返回 + 家庭名 */
.nav-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 28rpx 12rpx;
  box-sizing: border-box;
}

.back-label {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.back-label:active {
  opacity: 0.7;
}

.back-arrow {
  font-size: 52rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}

.back-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.family-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.22);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 第二行：分类筛选 */
.filter-scroll {
  width: 100%;
  height: 72rpx;
  box-sizing: border-box;
}

.filter-list {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 20rpx;
  gap: 12rpx;
  width: max-content;
  height: 72rpx;
}

.chip {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 52rpx;
  padding: 0 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.18);
  color: rgba(255, 255, 255, 0.88);
  font-size: 24rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.chip-on {
  background: #fff;
  color: #1a7ff0;
  font-weight: 600;
}

/* 第三行：搜索框 */
.search-row {
  width: 100%;
  padding: 12rpx 24rpx 18rpx;
  box-sizing: border-box;
}

.search-box {
  width: 100%;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 0 18rpx;
  height: 72rpx;
  box-sizing: border-box;
}

.search-ic {
  font-size: 26rpx;
  opacity: 0.75;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-inp {
  flex: 1;
  font-size: 26rpx;
  color: #fff;
  height: 72rpx;
  line-height: 72rpx;
}

.search-clear {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.28);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  flex-shrink: 0;
}

/* ============================
   主体 scroll-view
   ============================ */
.body {
  flex: 1;
  width: 100%;
  height: 0;
  box-sizing: border-box;
}

/* 数量栏 */
.count-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 14rpx;
}

.count-desc {
  font-size: 24rpx;
  color: #9fb8cc;
}

.count-right {
  display: flex;
  align-items: baseline;
}

.count-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a7ff0;
  font-family: 'DIN Alternate', 'PingFang SC', sans-serif;
}

.count-unit {
  font-size: 22rpx;
  color: #9fb8cc;
}

/* 空态 */
.empty {
  margin: 20rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 64rpx 40rpx;
  text-align: center;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2740;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #9fb8cc;
  line-height: 1.6;
  margin-bottom: 28rpx;
}

.empty-btn {
  display: inline-flex;
  align-items: center;
  padding: 18rpx 36rpx;
  border-radius: 34rpx;
  background: #1a7ff0;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(26, 127, 240, 0.28);
}

.empty-btn:active {
  opacity: 0.85;
}

/* ============================
   事项列表
   ============================ */
.list {
  padding: 4rpx 24rpx 0;
}

.event-item {
  background: #fff;
  border-radius: 22rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.event-item:active {
  opacity: 0.88;
  transform: scale(0.992);
}

/* 左侧：分类图标 */
.item-icon-wrap {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.item-icon-emoji {
  font-size: 38rpx;
  line-height: 1;
}

/* 中间：信息区 */
.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2740;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.5rpx;
}

.item-meta-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  flex-wrap: nowrap;
}

.item-date {
  font-size: 22rpx;
  color: #9fb8cc;
  font-family: 'DIN Alternate', 'PingFang SC', sans-serif;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

/* 标签胶囊 */
.tag-pill {
  font-size: 20rpx;
  padding: 3rpx 12rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.tag-remind {
  color: #2fcf7a;
  background: rgba(47, 207, 122, 0.12);
}

.tag-lunar {
  color: #4facfe;
  background: rgba(79, 172, 254, 0.12);
}

/* 右侧：分类标签 */
.item-badge {
  border-radius: 20rpx;
  padding: 6rpx 18rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-badge-text {
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

.bottom-space {
  height: 180rpx;
}

/* ============================
   悬浮新增按钮
   ============================ */
.fab {
  position: fixed;
  right: 36rpx;
  bottom: 80rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  background: linear-gradient(135deg, #1a7ff0 0%, #4facfe 100%);
  box-shadow: 0 12rpx 32rpx rgba(26, 127, 240, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
}

.fab:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.fab-plus {
  color: #fff;
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
}

/* 临时用户体验模式提示条 */
.temp-banner {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fff7e6 0%, #fff0d4 100%);
  border: 1rpx solid #ffd591;
  border-radius: 16rpx;
  margin: 16rpx 24rpx 0;
  padding: 18rpx 20rpx;
  gap: 10rpx;
}

.temp-banner-icon {
  font-size: 30rpx;
  flex-shrink: 0;
}

.temp-banner-text {
  flex: 1;
  font-size: 24rpx;
  color: #d46b08;
  line-height: 1.4;
}
