/* pages/index/index.wxss */
page {
  background: linear-gradient(180deg, #b8d4e8 0%, #d8e8f0 50%, #e8f0f5 100%);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  position: relative;
  padding-bottom: 120rpx; /* 为底部导航留出空间 */
}

/* 顶部标题区域 */
.header {
  text-align: center;
  padding: 10rpx 10rpx 10rpx 10rpx;
  position: relative;
}

.title {
  font-size: 72rpx;
  font-weight: bold;
  color: hsl(0, 0%, 0%); /* 纯黑色 */
  margin-bottom: 20rpx;
  letter-spacing: 6rpx;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  text-align: center; /* 确保文字居中 */
}

.subtitle {
  font-size: 28rpx;
  color: #5a6c7d;
  letter-spacing: 1rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.subtitle text {
  color: #5a6c7d;
}

.days-num {
  font-size: 38rpx !important;
  font-weight: bold !important;
  color: #ff6b6b !important;
  margin: 0 6rpx;
}

/* 最近回忆区域 */
.memories-section {
  margin: 5rpx;
  width: 80%;
  padding: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 20rpx;
  text-align: left;
  padding-left: 10rpx;
}

.memories-carousel {
  width: 100%;
  height: 380rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.swiper {
  width: 100%;
  height: 100%;
}

.memory-image {
  width: 100%;
  height: 100%;
}

.memory-placeholder {
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #a0aec0;
  font-size: 26rpx;
}

.placeholder-tip {
  font-size: 22rpx;
  margin-top: 12rpx;
  opacity: 0.8;
}

/* 功能菜单区域 */
.menu-section {
  margin: 0 5%;
  padding-bottom: 40rpx;
}

.menu-item {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 32rpx 80rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.menu-item:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.95);
}

.menu-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.love-icon {
  background: linear-gradient(135deg, #ff85a7 0%, #ff6b9d 100%);
}

.home-icon {
  background: linear-gradient(135deg, #5eb8ff 0%, #4facfe 100%);
}

.important-icon {
  background: linear-gradient(135deg, #5dffa8 0%, #43e97b 100%);
}

.icon-svg {
  width: 56rpx;
  height: 56rpx;
}

.menu-content {
  flex: 1;
  margin-right: 16rpx;
}

.menu-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 8rpx;
}

.menu-desc {
  font-size: 26rpx;
  color: #8b9dc3;
  line-height: 1.4;
}

.menu-arrow {
  font-size: 44rpx;
  color: #cbd5e0;
  font-weight: 300;
  line-height: 1;
}

/* 底部导航栏 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 40rpx;
  transition: all 0.3s ease;
}

.nav-item.active .nav-icon {
  transform: scale(1.1);
}

.nav-item.active .nav-text {
  color: #667eea;
  font-weight: 600;
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 6rpx;
}

.nav-icon-text {
  font-size: 48rpx;
  margin-bottom: 6rpx;
  line-height: 1;
}

.nav-item.active .nav-icon-text {
  transform: scale(1.1);
}

.nav-text {
  font-size: 22rpx;
  color: #8b9dc3;
  transition: all 0.3s ease;
}

