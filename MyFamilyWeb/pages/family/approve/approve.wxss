/* pages/family/approve/approve.wxss */

page {
  background: linear-gradient(160deg, #b8d4e8 0%, #d8e8f0 40%, #e8f4fd 100%);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 100rpx 40rpx 60rpx;
  box-sizing: border-box;
}

/* 顶部标题区 */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 52rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.page-subtitle {
  font-size: 25rpx;
  color: #6b7c8d;
  text-align: center;
  line-height: 1.6;
}

/* 加载中 */
.loading-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid rgba(255, 255, 255, 0.4);
  border-top-color: #5a9fd4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #6b7c8d;
}

/* 空态 */
.empty-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
  line-height: 1;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4a5568;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9fb3c2;
}

/* 成员卡片列表 */
.list-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.member-card {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 24rpx;
  padding: 36rpx 36rpx 32rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
}

/* 成员信息行 */
.member-info {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 28rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-default {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #4facfe 0%, #3d9ae8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.avatar-default-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.member-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 10rpx;
}

.apply-time {
  font-size: 24rpx;
  color: #9fb3c2;
}

/* 操作按钮行 */
.action-row {
  display: flex;
  gap: 20rpx;
}

.reject-btn,
.approve-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 38rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.reject-btn::after,
.approve-btn::after {
  border: none;
}

.reject-btn {
  background: rgba(231, 76, 60, 0.08);
  border: 2rpx solid rgba(231, 76, 60, 0.25);
}

.reject-btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #e74c3c;
  letter-spacing: 1rpx;
}

.approve-btn {
  background: linear-gradient(135deg, #4facfe 0%, #3d9ae8 100%);
  box-shadow: 0 4rpx 14rpx rgba(79, 172, 254, 0.35);
}

.approve-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 1rpx;
}

.btn-disabled {
  opacity: 0.5;
}
