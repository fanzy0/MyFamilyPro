<!--pages/family/approve/approve.wxml-->
<view class="container">

  <!-- 顶部标题区 -->
  <view class="header-section">
    <text class="page-title">成员审批</text>
    <text class="page-subtitle">仅家庭户主可在此批准或拒绝加入申请</text>
  </view>

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空态：无待审批 -->
  <view class="empty-wrap" wx:elif="{{pendingList.length === 0}}">
    <text class="empty-icon">✅</text>
    <text class="empty-title">暂无待审批申请</text>
    <text class="empty-desc">当前没有成员申请加入家庭</text>
  </view>

  <!-- 待审批列表 -->
  <view class="list-section" wx:else>
    <view
      class="member-card"
      wx:for="{{pendingList}}"
      wx:key="familyMemberId"
    >
      <!-- 成员头像与信息 -->
      <view class="member-info">
        <view class="avatar-wrap">
          <image
            wx:if="{{item.avatarUrl}}"
            class="avatar-img"
            src="{{item.avatarUrl}}"
            mode="aspectFill"
          />
          <view wx:else class="avatar-default">
            <text class="avatar-default-text">{{item.nickname ? item.nickname.substring(0,1) : '人'}}</text>
          </view>
        </view>
        <view class="member-detail">
          <text class="member-name">{{item.nickname || '家庭成员'}}</text>
          <text class="apply-time">申请时间：{{item.applyTime}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="action-row">
        <button
          class="reject-btn {{operatingId === item.familyMemberId ? 'btn-disabled' : ''}}"
          bindtap="onRejectTap"
          data-family-member-id="{{item.familyMemberId}}"
          data-index="{{index}}"
          disabled="{{operatingId === item.familyMemberId}}"
        >
          <text class="reject-btn-text">拒绝</text>
        </button>
        <button
          class="approve-btn {{operatingId === item.familyMemberId ? 'btn-disabled' : ''}}"
          bindtap="onApproveTap"
          data-family-member-id="{{item.familyMemberId}}"
          data-index="{{index}}"
          disabled="{{operatingId === item.familyMemberId}}"
        >
          <text class="approve-btn-text">同意</text>
        </button>
      </view>
    </view>
  </view>

</view>
