<!--pages/family/create/create.wxml-->
<view class="container">

  <!-- 顶部标题区 -->
  <view class="header-section">
    <view class="header-icon-wrap">
      <text class="header-icon">🏠</text>
    </view>
    <text class="page-title">创建我的家庭</text>
    <text class="page-subtitle">以你为户主，管理家庭中的重要事项与提醒</text>
  </view>

  <!-- 表单区 -->
  <view class="form-section">
    <view class="form-card">

      <!-- 家庭名称 -->
      <view class="field-label">家庭名称</view>
      <input
        class="field-input"
        type="text"
        placeholder="{{placeholderText}}"
        placeholder-class="field-placeholder"
        value="{{familyName}}"
        maxlength="20"
        bindinput="onFamilyNameInput"
        confirm-type="done"
      />
      <view class="field-line"></view>
      <text class="field-tip">家庭名称仅用于展示，成员加入时可看到该名称</text>

      <view class="field-spacer"></view>

      <!-- 相识相遇时间（可选） -->
      <view class="field-label">
        相识时间
        <text class="field-optional">（选填）</text>
      </view>
      <picker
        mode="date"
        value="{{meetDate}}"
        end="{{today}}"
        bindchange="onMeetDateChange"
      >
        <view class="date-picker-row">
          <text class="{{meetDate ? 'date-value' : 'date-placeholder'}}">
            {{meetDate || '选择你们相识相遇的日期'}}
          </text>
          <view class="date-actions">
            <text class="date-clear" catchtap="onClearMeetDate" wx:if="{{meetDate}}">✕</text>
            <text class="date-arrow">›</text>
          </view>
        </view>
      </picker>
      <view class="field-line"></view>
      <text class="field-tip">用于在家庭主页展示"一起走过的 XX 天"💝</text>

    </view>
  </view>

  <!-- 底部操作区 -->
  <view class="action-section">
    <button
      class="primary-btn {{submitting ? 'primary-btn-loading' : ''}}"
      bindtap="onCreateTap"
      disabled="{{submitting}}"
    >
      <text class="btn-text">{{submitting ? '创建中...' : '创建家庭'}}</text>
    </button>
  </view>

</view>
