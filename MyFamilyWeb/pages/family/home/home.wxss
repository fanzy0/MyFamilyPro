/* pages/family/home/home.wxss */

/* ============================
   页面基础
   ============================ */
page {
  background: #f0f4f8;
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* ============================
   加载遮罩
   ============================ */
.loading-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #6ab4d8 0%, #a8d5e8 50%, #d0ebf5 100%);
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 5rpx solid rgba(255,255,255,0.35);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}

/* ============================
   主体滚动容器
   ============================ */
.home-body {
  flex: 1;
  height: 100vh;
}

/* ============================
   顶部头部区域
   ============================ */
.header-section {
  position: relative;
  height: 280rpx;
  overflow: hidden;
}

/* 渐变背景：梅花色 */
.header-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(
    180deg,
    #b05470 0%,
    #c8697e 25%,
    #da8fa0 50%,
    #edb8c4 75%,
    #f5d8e0 100%
  );
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80%;
  padding-top: 80rpx;
  box-sizing: border-box;
}

.family-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 18rpx;
}

.together-days-wrap {
  display: flex;
  align-items: baseline;
  padding: 4rpx 0;
}

.together-prefix,
.together-suffix {
  font-size: 26rpx;
  color: rgba(255,255,255,0.92);
}

.together-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
  margin: 0 6rpx;
  font-family: 'DIN Alternate', 'PingFang SC', sans-serif;
}

.together-none {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}

/* ============================
   Tab 通用内容容器
   ============================ */
.tab-content {
  padding: 28rpx 32rpx 32rpx;
}

/* ============================
   最近回忆区域
   ============================ */
.memories-section {
  margin-bottom: 32rpx;
}

/* 标题行 */
.memories-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.memories-title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.memories-title-icon {
  font-size: 32rpx;
}

.memories-title {
  font-size: 20rpx;
  font-weight: 600;
  color: #2c4b50;
}

.memories-count {
  font-size: 22rpx;
  color: #9aabb8;
  background: #edf2f7;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

/* 双击提示文字 */
.memories-hint {
  font-size: 22rpx;
  color: #b0bec5;
}

/* 轮播容器 */
.memory-swiper {
  height: 360rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.14);
}

/* 图片容器（相对定位，让删除按钮绝对定位） */
.memory-item-wrap {
  position: relative;
  width: 100%;
  height: 100%;
}

.memory-image {
  width: 100%;
  height: 100%;
}

.memory-image-loading {
  opacity: 0;
}

/* 图片加载中占位 */
.memory-img-placeholder {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e8f5ff 0%, #d0e8f8 100%);
}

.memory-img-spinner {
  width: 52rpx;
  height: 52rpx;
  border: 4rpx solid rgba(74, 144, 217, 0.2);
  border-top-color: #4a90d9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* 上传中遮罩 */
.memory-uploading-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  z-index: 10;
}

.memory-uploading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.memory-uploading-text {
  font-size: 26rpx;
  color: #fff;
}

.memory-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #e8f5ff 0%, #d0e8f8 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
  display: block;
}

.placeholder-text {
  font-size: 26rpx;
  color: #8bafc4;
}

/* ============================
   功能菜单区（首页 Tab）
   ============================ */
.menu-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.menu-item:active {
  opacity: 0.82;
  transform: scale(0.988);
}

.menu-icon-wrap {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 28rpx;
}

.love-bg {
  background: linear-gradient(135deg, #ff6b9d 0%, #ff4b7d 100%);
}

.home-bg {
  background: linear-gradient(135deg, #4facfe 0%, #00c9ff 100%);
}

.important-bg {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.menu-icon-emoji {
  font-size: 38rpx;
  line-height: 1;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2740;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #9fb8cc;
  line-height: 1.4;
}

.menu-arrow {
  font-size: 44rpx;
  color: #c8d8e4;
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* ============================
   我的 Tab — 家庭信息概览卡（与 my-item 保持一致高度）
   ============================ */
.my-profile-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 16rpx;
}

.my-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #c8697e 0%, #da8fa0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.my-avatar-icon {
  font-size: 36rpx;
  line-height: 1;
}

.my-profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.my-profile-arrow {
  font-size: 44rpx;
  color: #c8d8e4;
  font-weight: 300;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.my-profile-card:active {
  background: #f8fafc;
}

.my-family-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a2740;
  margin-bottom: 7rpx;
  letter-spacing: 1rpx;
}

.my-role-text {
  font-size: 22rpx;
  color: #9fb8cc;
  line-height: 1.4;
}

/* ============================
   家庭详情弹层
   ============================ */
.family-detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 999;
}

.family-detail-panel {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 640rpx;
  max-height: 78vh;
  background: #fff;
  border-radius: 24rpx;
  z-index: 1000;
  overflow: hidden;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.18);
  display: flex;
  flex-direction: column;
}

.family-detail-header {
  padding: 28rpx 28rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #edf1f7;
}

.family-detail-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2740;
}

.family-detail-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #f4f7fb;
  display: flex;
  align-items: center;
  justify-content: center;
}

.family-detail-close-text {
  font-size: 26rpx;
  color: #7a8c9c;
}

.family-detail-body {
  padding: 20rpx 24rpx 24rpx;
  flex: 1;
  min-height: 0;
}

.family-detail-loading,
.family-detail-empty {
  padding: 60rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.family-detail-spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 6rpx solid #f0f4f8;
  border-top-color: #4facfe;
  animation: spin 0.8s linear infinite;
}

.family-detail-loading-text,
.family-detail-empty-text {
  font-size: 26rpx;
  color: #8a9bb0;
}

.family-detail-card {
  background: #f8fafd;
  border-radius: 20rpx;
  padding: 18rpx 18rpx 6rpx;
  border: 1rpx solid #edf1f7;
}

.family-detail-row {
  display: flex;
  align-items: center;
  padding: 14rpx 8rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.family-detail-row-last {
  border-bottom: none;
}

.family-detail-label {
  width: 96rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #7a8c9c;
}

.family-detail-value {
  flex: 1;
  font-size: 26rpx;
  color: #1a2740;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.family-detail-code {
  flex: 1;
  font-size: 26rpx;
  color: #1a2740;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.family-detail-copy {
  flex-shrink: 0;
  margin-left: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(79, 172, 254, 0.12);
}

.family-detail-copy-text {
  font-size: 22rpx;
  color: #4facfe;
  font-weight: 600;
}

.family-detail-members {
  margin-top: 18rpx;
}

.family-detail-members-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a2740;
  margin: 10rpx 4rpx 14rpx;
}

.family-detail-members-scroll {
  max-height: 360rpx;
}

.family-detail-member {
  display: flex;
  align-items: center;
  padding: 16rpx 8rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.family-detail-member:last-child {
  border-bottom: none;
}

.family-detail-member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #d7eef8, #a8d4f0);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 18rpx;
}

.family-detail-member-avatar-text {
  font-size: 30rpx;
  color: #1a2740;
  font-weight: 700;
}

.family-detail-member-info {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
}

.family-detail-member-name {
  font-size: 26rpx;
  color: #1a2740;
  font-weight: 600;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.family-detail-member-role {
  font-size: 22rpx;
  color: #9fb8cc;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ============================
   我的 Tab — 功能列表
   ============================ */
.my-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.my-group {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.my-item {
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
}

.my-item:active {
  background: #f8fafc;
}

.my-item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.edit-bg { background: linear-gradient(135deg, #f8d7e8, #f0a8c8); }
.switch-bg { background: linear-gradient(135deg, #d7eef8, #a8d4f0); }
.approve-bg { background: linear-gradient(135deg, #d7e8f8, #a8c8f0); }
.add-bg { background: linear-gradient(135deg, #d7f8e8, #a8f0c8); }

.my-item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.my-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a2740;
  margin-bottom: 7rpx;
  letter-spacing: 1rpx;
}

.my-item-desc {
  font-size: 22rpx;
  color: #9fb8cc;
  line-height: 1.4;
}

.my-item-arrow {
  font-size: 44rpx;
  color: #c8d8e4;
  font-weight: 300;
  margin-left: 8rpx;
  flex-shrink: 0;
  transition: transform 0.25s ease;
  display: inline-block;
}

.arrow-rotate {
  transform: rotate(90deg);
}

/* 红点徽标 */
.badge-wrap {
  margin-right: 8rpx;
}

.badge-dot {
  background: #ff4b6e;
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  text-align: center;
  line-height: 36rpx;
  padding: 0 10rpx;
  box-sizing: border-box;
}

/* ============================
   展开面板（家庭切换 / 成员审批）
   ============================ */
.expand-panel {
  background: #f8fafd;
  border-top: 1rpx solid #edf1f7;
  padding: 8rpx 36rpx 20rpx;
}

/* expand-panel 的嵌套版本：用于父级面板内部的二级展开内容 */
.expand-panel-inner {
  background: transparent;
  border-top: none;
  padding: 0;
}

/* 家庭切换列表项 */
.family-switch-item {
  display: flex;
  align-items: center;
  padding: 24rpx 4rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.family-switch-item:last-child {
  border-bottom: none;
}

.radio-wrap {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.radio-outer {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #c8d8e4;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.radio-outer-checked {
  border-color: #4facfe;
  background: rgba(79, 172, 254, 0.08);
}

.radio-inner {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #4facfe;
}

.family-switch-name {
  flex: 1;
  font-size: 28rpx;
  color: #2c3e50;
}

.family-switch-active .family-switch-name {
  color: #4facfe;
  font-weight: 600;
}

.family-switch-badge {
  font-size: 20rpx;
  color: #9fb8cc;
  background: #edf3f8;
  padding: 4rpx 16rpx;
  border-radius: 14rpx;
}

/* 审批列表 */
.approval-loading,
.approval-empty {
  text-align: center;
  padding: 40rpx 0 24rpx;
  font-size: 26rpx;
  color: #9fb8cc;
}

.approval-item {
  display: flex;
  align-items: center;
  padding: 24rpx 4rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.approval-item:last-child {
  border-bottom: none;
}

.approval-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #a18cd1, #fbc2eb);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  overflow: hidden;
}

.approval-avatar-img {
  width: 100%;
  height: 100%;
}

.approval-avatar-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.approval-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.approval-name {
  font-size: 28rpx;
  color: #2c3e50;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.approval-time {
  font-size: 20rpx;
  color: #9fb8cc;
}

.approval-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.btn-approve {
  background: linear-gradient(135deg, #4facfe, #00c9ff);
  color: #fff;
  font-size: 22rpx;
  font-weight: 500;
  padding: 12rpx 26rpx;
  border-radius: 28rpx;
}

.btn-approve:active {
  opacity: 0.8;
}

.btn-reject {
  background: #f0f4f8;
  color: #9fb8cc;
  font-size: 22rpx;
  font-weight: 500;
  padding: 12rpx 26rpx;
  border-radius: 28rpx;
  border: 1rpx solid #dde6ee;
}

.btn-reject:active {
  opacity: 0.8;
}

/* ============================
   底部固定导航
   ============================ */
.bottom-placeholder {
  height: 160rpx;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.07);
  padding-top: 16rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
  z-index: 100;
}

.nav-item {
  width: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx 16rpx;
}

.nav-emoji {
  font-size: 44rpx;
  line-height: 1;
  margin-bottom: 6rpx;
  display: block;
  opacity: 0.35;
  transition: opacity 0.2s;
}

.nav-emoji-active {
  opacity: 1;
}

.nav-label {
  font-size: 22rpx;
  color: #b0c4d4;
  transition: color 0.2s;
  line-height: 1;
}

.nav-active .nav-label {
  color: #c8697e;
  font-weight: 600;
}

/* ============================
   提醒浮层相关样式
   ============================ */

/* 悬浮按钮（FAB） */
.remind-fab {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #c8697e 0%, #e8956e 100%);
  box-shadow: 0 8rpx 24rpx rgba(200, 105, 126, 0.45);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: transform 0.15s;
}

.remind-fab:active {
  transform: scale(0.92);
}

.remind-fab-icon {
  font-size: 42rpx;
  line-height: 1;
}

/* 红点角标 */
.remind-fab-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #ff4b4b;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #fff;
}

.remind-fab-badge-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

/* 半透明遮罩 */
.remind-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 101;
}

/* 提醒浮层主体 */
.remind-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  /* 给定固定高度，让 flex 子项（scroll-view）可以计算自身高度 */
  height: 68vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 102;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12);
  /* 适配 iPhone 底部安全区 */
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

.remind-panel-show {
  transform: translateY(0);
}

/* 浮层顶部拖拽指示条区域 */
.remind-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 36rpx 16rpx;
  flex-shrink: 0;
}

.remind-panel-drag-bar {
  position: absolute;
  top: 14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #e0e0e0;
}

.remind-panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d3a45;
}

.remind-panel-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f5f6fa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #8a9bb0;
}

/* 浮层滚动区 */
.remind-panel-scroll {
  flex: 1;
  overflow: hidden;
  padding: 0 24rpx 32rpx;
}

/* 加载中提示 */
.remind-loading {
  padding: 60rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #b0c4d4;
}

/* 空状态 */
.remind-empty {
  padding: 80rpx 0;
  text-align: center;
}

.remind-empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.remind-empty-text {
  font-size: 28rpx;
  color: #b0c4d4;
}

/* 浮层滚动列表：必须用 flex:1 + height:0 组合，scroll-view 才能在真机正确计算高度 */
.remind-list-scroll {
  flex: 1;
  height: 0;
  min-height: 0;
  padding: 0 24rpx 16rpx;
  box-sizing: border-box;
}

/* 加载 / 空态 通用容器 */
.remind-state-box {
  padding: 80rpx 0 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.remind-loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 6rpx solid #f0f4f8;
  border-top-color: #c8697e;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.remind-state-emoji {
  font-size: 72rpx;
}

.remind-state-text {
  font-size: 28rpx;
  color: #8a9bb0;
}

.remind-state-sub {
  font-size: 24rpx;
  color: #b0c4d4;
}

/* 浮层标题行（图标 + 文字 + 数量标签） */
.remind-panel-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.remind-panel-header-icon {
  font-size: 36rpx;
}

.remind-count-tag {
  background: #ffeef1;
  border-radius: 20rpx;
  padding: 4rpx 14rpx;
}

.remind-count-tag-text {
  font-size: 22rpx;
  color: #c8697e;
  font-weight: 600;
}

.remind-close-text {
  font-size: 26rpx;
}

/* 底部安全区（保留 DOM 节点但不再额外占高，由 panel 的 padding-bottom 统一处理） */
.remind-panel-safe {
  height: 0;
  flex-shrink: 0;
}

/* 单条提醒卡片 */
.remind-item {
  background: #f8f9fc;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
}

.remind-item-emoji-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.remind-item-emoji {
  font-size: 36rpx;
  line-height: 1;
}

/* 中间信息区 */
.remind-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.remind-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3a45;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 日期倒计时文案（含颜色主题） */
.remind-item-date {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}

.date-expired { background: #fff0f0; color: #e85d5d; }
.date-today   { background: #fff4e0; color: #e8963e; }
.date-soon    { background: #fff7e0; color: #c8a020; }
.date-normal  { background: #f0f4f8; color: #5a7a96; }

.remind-item-advance {
  font-size: 20rpx;
  color: #b0c4d4;
}

/* 右侧操作按钮列 */
.remind-item-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.btn-remind-done {
  min-width: 120rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #c8697e 0%, #e8956e 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(200, 105, 126, 0.3);
}

.btn-remind-ignore {
  min-width: 120rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #f0f4f8;
  color: #8a9bb0;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ============================================================
   信息修改 — 子选项与昵称编辑区
   ============================================================ */

/* 子选项行（修改个人信息 / 修改家庭信息） */
.edit-sub-item {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  /* 二级项加了左侧图标后：与父级保持同一内边距风格 */
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid #edf1f7;
  box-sizing: border-box;
}

.edit-sub-item:active {
  background: #f8fafc;
}

.edit-sub-item-last {
  border-bottom: none;
}

.edit-sub-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a2740;
  letter-spacing: 1rpx;
  flex: 1;
  white-space: nowrap;
}

.edit-sub-arrow {
  /* 与父级 my-item-arrow 保持一致的视觉与旋转手感 */
  font-size: 44rpx;
  color: #c8d8e4;
  font-weight: 300;
  flex-shrink: 0;
  transition: transform 0.25s ease;
  display: inline-block;
}

/* 昵称编辑区容器 */
.edit-profile-panel {
  background: #fff;
  border-radius: 16rpx;
  margin: 8rpx 0 12rpx;
  padding: 24rpx 20rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 字段行：label + input 横排 */
.edit-field-row {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  /* 该字段行后紧跟“保存昵称”，避免底部分隔线/间距造成“多一行”的错觉 */
  padding: 0 0 12rpx;
  border-bottom: none;
  margin-bottom: 16rpx;
}

.edit-field-row-last {
  margin-bottom: 18rpx;
}

/* picker 组件直接作为 flex 子项：强制 flex:1 参与横向布局 */
.edit-meet-picker {
  flex: 1;
  min-width: 0;
}

/* picker 内部触发区：display:flex + nowrap 确保文字与箭头同行 */
.edit-picker-trigger {
  display: flex;
  align-items: center;
  height: 56rpx;
  min-width: 0;
  white-space: nowrap;
}

.edit-picker-text {
  font-size: 26rpx;
  color: #2c3e50;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-picker-placeholder {
  color: #c0ccd8;
}

.edit-picker-arrow {
  font-size: 40rpx;
  color: #c8d8e4;
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.edit-picker-clear {
  flex-shrink: 0;
  margin-left: 8rpx;
  padding: 6rpx 10rpx;
  border-radius: 16rpx;
  background: #f0f4f8;
}

.edit-picker-clear-text {
  font-size: 20rpx;
  color: #7a8c9c;
  font-weight: 600;
  white-space: nowrap;
}

.edit-field-label {
  font-size: 26rpx;
  color: #7a8c9c;
  flex-shrink: 0;
  width: 80rpx;
  white-space: nowrap;
  height: 56rpx;
  display: flex;
  align-items: center;
}


.edit-field-input {
  flex: 1;
  font-size: 28rpx;
  color: #2c3e50;
  height: 56rpx;
  line-height: 56rpx;
}

.edit-field-placeholder {
  color: #c0ccd8;
}

/* 保存按钮 */
.edit-save-btn {
  width: 100%;
  height: 76rpx;
  background: linear-gradient(135deg, #5eb8ff 0%, #4facfe 100%);
  border-radius: 38rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(79, 172, 254, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  white-space: nowrap;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2rpx;
  padding: 0;
}

.edit-save-btn::after {
  border: none;
}

.edit-save-btn-loading {
  background: linear-gradient(135deg, #a8d4f8 0%, #90c4f4 100%);
  box-shadow: none;
}

/* 退出登录 */
.logout-bg {
  background: linear-gradient(135deg, #e8f0f8, #c8d8f0);
}

/* 注销账号 */
.deactivate-bg {
  background: linear-gradient(135deg, #ffe0e0 0%, #ffd0d0 100%);
}

.my-item-danger {
  border-top: 1rpx solid #fff0f0;
}

.my-item-title-danger {
  color: #e53e3e;
}

/* ============================
   临时用户体验模式提示条
   ============================ */
.temp-banner {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fff7e6 0%, #fff0d4 100%);
  border: 1rpx solid #ffd591;
  border-radius: 16rpx;
  margin: 24rpx 24rpx 8rpx;
  padding: 20rpx 24rpx;
  gap: 12rpx;
}

.temp-banner-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.temp-banner-text {
  flex: 1;
  font-size: 26rpx;
  color: #d46b08;
  line-height: 1.4;
}

.temp-banner-arrow {
  font-size: 32rpx;
  color: #d46b08;
  flex-shrink: 0;
}
