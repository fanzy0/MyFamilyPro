<!--pages/family/home/home.wxml-->
<view class="container">

  <!-- 登录弹窗组件（全局挂载，写操作守卫时调用 show()） -->
  <login-modal id="loginModal" bind:loginSuccess="onLoginSuccess"></login-modal>

  <!-- 加载中 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <!-- 家庭主页内容 -->
  <scroll-view class="home-body" scroll-y wx:elif="{{currentFamily}}">

    <!-- 顶部头部区域（两个 Tab 均保留） -->
    <view class="header-section">
      <view class="header-overlay"></view>
      <view class="header-content">
        <text class="family-title">{{currentFamily.familyName}}</text>
        <view class="together-days-wrap" wx:if="{{togetherDays !== null}}">
          <text class="together-prefix">一起走过了 </text>
          <text class="together-num">{{togetherDays}}</text>
          <text class="together-suffix"> 天</text>
        </view>
        <text class="together-none" wx:else>记录每一个温馨时刻</text>
      </view>
    </view>

    <!-- ===== 首页 Tab 内容 ===== -->
    <view class="tab-content" wx:if="{{activeTab === 'home'}}">

      <!-- 临时用户体验模式提示条 -->
      <view class="temp-banner" wx:if="{{isTempLogin}}" bindtap="onTempUserLoginTap">
        <text class="temp-banner-icon">👋</text>
        <text class="temp-banner-text">您正在体验模式下浏览，点击登录解锁全部功能</text>
        <text class="temp-banner-arrow">›</text>
      </view>

      <!-- 最近回忆 -->
      <view class="memories-section">

        <!-- 标题行（纯展示，操作通过双击图片触发） -->
        <view class="memories-header">
          <view class="memories-title-wrap">
            <text class="memories-title">时光剪影</text>
          </view>
        </view>

        <!-- 轮播图 -->
        <swiper
          class="memory-swiper"
          indicator-dots="{{memoryImages.length > 1}}"
          autoplay="{{memoryImages.length > 1 && !uploadingMemory}}"
          interval="{{3000}}"
          duration="{{500}}"
          circular="{{true}}"
          indicator-color="rgba(255,255,255,0.5)"
          indicator-active-color="#fff"
          bindchange="onMemorySwiperChange"
        >
          <!-- 有图片时：点击事件用于检测双击 -->
          <swiper-item wx:for="{{memoryImages}}" wx:key="bannerId">
            <view
              class="memory-item-wrap"
              bindtap="onMemoryTap"
            >
              <image
                class="memory-image {{item.loaded ? '' : 'memory-image-loading'}}"
                src="{{item.src}}"
                mode="aspectFill"
              ></image>
              <!-- 图片加载中转圈 -->
              <view class="memory-img-placeholder" wx:if="{{!item.loaded}}">
                <view class="memory-img-spinner"></view>
              </view>
              <!-- 上传进度遮罩 -->
              <view class="memory-uploading-mask" wx:if="{{uploadingMemory}}">
                <view class="memory-uploading-spinner"></view>
                <text class="memory-uploading-text">上传中...</text>
              </view>
            </view>
          </swiper-item>

          <!-- 无图片时：点击直接添加 -->
          <swiper-item wx:if="{{memoryImages.length === 0}}">
            <view class="memory-placeholder" bindtap="onAddMemory">
              <text class="placeholder-icon">🌸</text>
              <text class="placeholder-text">暂无回忆，轻触此处添加第一张~</text>
            </view>
          </swiper-item>
        </swiper>

      </view>

      <!-- 功能菜单 -->
      <view class="menu-section">

        <!-- 执子之手 -->
        <!-- <view class="menu-item" bindtap="navigateToLove">
          <view class="menu-icon-wrap love-bg">
            <text class="menu-icon-emoji">❤️</text>
          </view>
          <view class="menu-content">
            <text class="menu-title">执子之手</text>
            <text class="menu-desc">记录我们的相识相恋</text>
          </view>
          <text class="menu-arrow">›</text>
        </view> -->

        <!-- 平安喜乐 -->
        <!-- <view class="menu-item" bindtap="navigateToHome">
          <view class="menu-icon-wrap home-bg">
            <text class="menu-icon-emoji">🏠</text>
          </view>
          <view class="menu-content">
            <text class="menu-title">平安喜乐</text>
            <text class="menu-desc">记录大家庭的点点滴滴</text>
          </view>
          <text class="menu-arrow">›</text>
        </view> -->

        <!-- 重要事项 -->
        <view class="menu-item" bindtap="navigateToImportant">
          <view class="menu-icon-wrap important-bg">
            <text class="menu-icon-emoji">📋</text>
          </view>
          <view class="menu-content">
            <text class="menu-title">重要事项</text>
            <text class="menu-desc">家庭年度提醒与记录</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>

      </view>
    </view>

    <!-- ===== 我的 Tab 内容 ===== -->
    <view class="tab-content" wx:if="{{activeTab === 'my'}}">

      <!-- 家庭信息概览卡 -->
      <view class="my-profile-card" bindtap="onOpenFamilyDetail">
        <view class="my-avatar">
          <text class="my-avatar-icon">👤</text>
        </view>
        <view class="my-profile-info">
          <text class="my-family-name">{{currentFamily.familyName}}</text>
          <text class="my-role-text">{{currentFamily.role === 'OWNER' ? '户主' : '成员'}} · {{currentFamily.memberCount}} 位成员</text>
        </view>
        <text class="my-profile-arrow">›</text>
      </view>

      <!-- 家庭详情弹层 -->
      <view class="family-detail-mask" wx:if="{{showFamilyDetail}}" bindtap="onCloseFamilyDetail"></view>
      <view class="family-detail-panel" wx:if="{{showFamilyDetail}}">
        <view class="family-detail-header">
          <text class="family-detail-title">家庭详情</text>
          <view class="family-detail-close" bindtap="onCloseFamilyDetail">
            <text class="family-detail-close-text">✕</text>
          </view>
        </view>

        <view class="family-detail-body">
          <view class="family-detail-loading" wx:if="{{familyDetailLoading}}">
            <view class="family-detail-spinner"></view>
            <text class="family-detail-loading-text">加载中...</text>
          </view>

          <view wx:elif="{{!familyDetailLoading && !familyDetail}}" class="family-detail-empty">
            <text class="family-detail-empty-text">暂无家庭详情</text>
          </view>

          <view wx:else>
            <view class="family-detail-card">
              <view class="family-detail-row">
                <text class="family-detail-label">名称</text>
                <text class="family-detail-value">{{familyDetail.familyName}}</text>
              </view>
              <view class="family-detail-row">
                <text class="family-detail-label">编号</text>
                <text class="family-detail-code">{{familyDetail.familyCode}}</text>
                <view class="family-detail-copy" bindtap="onCopyCode">
                  <text class="family-detail-copy-text">复制</text>
                </view>
              </view>
              <view class="family-detail-row family-detail-row-last">
                <text class="family-detail-label">成员</text>
                <text class="family-detail-value">{{familyDetail.memberCount}} 位</text>
              </view>
            </view>

            <view class="family-detail-members">
              <text class="family-detail-members-title">成员列表</text>
              <scroll-view scroll-y class="family-detail-members-scroll">
                <view class="family-detail-member" wx:for="{{familyDetail.members}}" wx:key="userId">
                  <view class="family-detail-member-avatar">
                    <text class="family-detail-member-avatar-text">{{item.avatarText}}</text>
                  </view>
                  <view class="family-detail-member-info">
                    <text class="family-detail-member-name">{{item.nickname || '未设置昵称'}}</text>
                    <text class="family-detail-member-role">{{item.role === 'OWNER' ? '户主' : '成员'}}</text>
                  </view>
                </view>
              </scroll-view>
            </view>
          </view>
        </view>
      </view>

      <!-- 我的功能列表 -->
      <view class="my-list">

        <!-- 信息修改 -->
        <view class="my-group">
          <view class="my-item" bindtap="onToggleEditInfo">
            <view class="my-item-icon edit-bg">✏️</view>
            <view class="my-item-content">
              <text class="my-item-title">信息修改</text>
              <text class="my-item-desc">修改个人昵称、家庭信息等</text>
            </view>
            <text class="my-item-arrow {{showEditInfo ? 'arrow-rotate' : ''}}">›</text>
          </view>

          <!-- 展开面板：选择修改类型 -->
          <view class="expand-panel" wx:if="{{showEditInfo}}">

            <!-- 子选项：修改个人信息 -->
            <view class="edit-sub-item" bindtap="onToggleEditProfile">
              <view class="my-item-icon edit-bg">✍️</view>
              <text class="edit-sub-label">修改个人信息</text>
              <text class="edit-sub-arrow {{showEditProfile ? 'arrow-rotate' : ''}}">›</text>
            </view>

            <!-- 昵称编辑区 -->
            <view class="edit-profile-panel" wx:if="{{showEditProfile}}">
              <view class="edit-field-row">
                <text class="edit-field-label">昵称</text>
                <input
                  class="edit-field-input"
                  type="nickname"
                  value="{{editNickname}}"
                  placeholder="请输入昵称"
                  placeholder-class="edit-field-placeholder"
                  bindinput="onNicknameInput"
                  maxlength="20"
                  confirm-type="done"
                />
              </view>
              <button
                class="edit-save-btn {{saveProfileLoading ? 'edit-save-btn-loading' : ''}}"
                bindtap="onSaveNickname"
                disabled="{{saveProfileLoading}}"
              >{{saveProfileLoading ? '保存中...' : '保存昵称'}}</button>
            </view>

            <!-- 子选项：修改家庭信息（预留） -->
            <view class="edit-sub-item edit-sub-item-last" bindtap="onEditFamilyInfo">
              <view class="my-item-icon switch-bg">📝</view>
              <text class="edit-sub-label">修改家庭信息</text>
              <text class="edit-sub-arrow {{showEditFamily ? 'arrow-rotate' : ''}}">›</text>
            </view>

            <!-- 家庭信息编辑区 -->
            <view class="edit-profile-panel" wx:if="{{showEditFamily}}">
              <view class="edit-field-row">
                <text class="edit-field-label">名称</text>
                <input
                  class="edit-field-input"
                  value="{{editFamilyName}}"
                  placeholder="请输入家庭名称"
                  placeholder-class="edit-field-placeholder"
                  bindinput="onFamilyNameInput"
                  maxlength="64"
                  confirm-type="done"
                />
              </view>

              <view class="edit-field-row edit-field-row-last">
                <text class="edit-field-label">相遇</text>
                <picker
                  class="edit-meet-picker"
                  mode="date"
                  value="{{editMeetDate}}"
                  bindchange="onMeetDateChange"
                >
                  <view class="edit-picker-trigger">
                    <text class="edit-picker-text {{editMeetDate ? '' : 'edit-picker-placeholder'}}">{{editMeetDate || '请选择日期（可不选）'}}</text>
                    <text class="edit-picker-arrow">›</text>
                  </view>
                </picker>
                <view class="edit-picker-clear" wx:if="{{editMeetDate}}" catchtap="onClearMeetDate">
                  <text class="edit-picker-clear-text">清空</text>
                </view>
              </view>

              <button
                class="edit-save-btn {{saveFamilyLoading ? 'edit-save-btn-loading' : ''}}"
                bindtap="onSaveFamilyInfo"
                disabled="{{saveFamilyLoading}}"
              >{{saveFamilyLoading ? '保存中...' : '保存家庭信息'}}</button>
            </view>

          </view>
        </view>

        <!-- 一级菜单：家庭管理 -->
        <view class="my-group">
          <view class="my-item" bindtap="onToggleFamilyManagement">
            <view class="my-item-icon switch-bg">🏠</view>
            <view class="my-item-content">
              <text class="my-item-title">家庭管理</text>
              <text class="my-item-desc">家庭切换、成员审批、加入/创建</text>
            </view>
            <text class="my-item-arrow {{showFamilyManagement ? 'arrow-rotate' : ''}}">›</text>
          </view>

          <view class="expand-panel" wx:if="{{showFamilyManagement}}">
            <!-- 二级菜单：家庭切换 -->
            <view class="edit-sub-item" bindtap="onToggleFamilySwitch">
              <view class="my-item-icon switch-bg">🔄</view>
              <text class="edit-sub-label">家庭切换</text>
              <text class="edit-sub-arrow {{showFamilySwitch ? 'arrow-rotate' : ''}}">›</text>
            </view>

            <view class="expand-panel expand-panel-inner" wx:if="{{showFamilySwitch}}">
              <view
                class="family-switch-item {{item.familyId === currentFamily.familyId ? 'family-switch-active' : ''}}"
                wx:for="{{familyList}}"
                wx:key="familyId"
                bindtap="onSwitchFamily"
                data-family-id="{{item.familyId}}"
              >
                <view class="radio-wrap">
                  <view class="radio-outer {{item.familyId === currentFamily.familyId ? 'radio-outer-checked' : ''}}">
                    <view class="radio-inner" wx:if="{{item.familyId === currentFamily.familyId}}"></view>
                  </view>
                </view>
                <text class="family-switch-name">{{item.familyName}}</text>
                <text class="family-switch-badge">{{item.role === 'OWNER' ? '户主' : '成员'}}</text>
              </view>
            </view>

            <!-- 二级菜单：成员审批（仅户主） -->
            <view class="edit-sub-item" wx:if="{{isOwner}}" bindtap="onToggleApproval">
              <view class="my-item-icon approve-bg">👥</view>
              <text class="edit-sub-label">成员审批</text>
              <text class="edit-sub-arrow {{showApproval ? 'arrow-rotate' : ''}}">›</text>
            </view>

            <view class="expand-panel expand-panel-inner" wx:if="{{showApproval}}">
              <view wx:if="{{approvLoading}}" class="approval-loading">
                <text>加载中...</text>
              </view>
              <view wx:elif="{{pendingMembers.length === 0}}" class="approval-empty">
                <text>暂无待审批成员 🎉</text>
              </view>
              <view class="approval-item" wx:for="{{pendingMembers}}" wx:key="id">
                <view class="approval-avatar">
                  <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="approval-avatar-img" mode="aspectFill"></image>
                  <text wx:else class="approval-avatar-text">{{item.nickname.substring(0,1)}}</text>
                </view>
                <view class="approval-info">
                  <text class="approval-name">{{item.nickname}}</text>
                  <text class="approval-time">{{item.applyTime}}</text>
                </view>
                <view class="approval-actions">
                  <view class="btn-approve" bindtap="onApprove" data-member-id="{{item.id}}">通过</view>
                  <view class="btn-reject" bindtap="onReject" data-member-id="{{item.id}}">拒绝</view>
                </view>
              </view>
            </view>

            <!-- 二级菜单：加入/创建家庭 -->
            <view class="edit-sub-item edit-sub-item-last" bindtap="onAddFamilyTap">
              <view class="my-item-icon add-bg">➕</view>
              <text class="edit-sub-label">加入/创建家庭</text>
              <text class="edit-sub-arrow">›</text>
            </view>
          </view>
        </view>

        <!-- 一级菜单：登录管理（临时用户：立即登录；真实用户：退出/注销） -->
        <view class="my-group">
          <!-- 临时用户：直接展示登录入口，点击弹出登录弹窗 -->
          <view class="my-item" wx:if="{{isTempLogin}}" bindtap="onTempUserLoginTap">
            <view class="my-item-icon logout-bg">🔑</view>
            <view class="my-item-content">
              <text class="my-item-title">立即登录</text>
              <text class="my-item-desc">登录后可使用完整功能</text>
            </view>
            <text class="my-item-arrow">›</text>
          </view>

          <!-- 真实用户：退出登录与账号注销 -->
          <view wx:else>
            <view class="my-item" bindtap="onToggleLoginManagement">
              <view class="my-item-icon logout-bg">🔐</view>
              <view class="my-item-content">
                <text class="my-item-title">登录管理</text>
                <text class="my-item-desc">退出登录与账号注销</text>
              </view>
              <text class="my-item-arrow {{showLoginManagement ? 'arrow-rotate' : ''}}">›</text>
            </view>

            <view class="expand-panel" wx:if="{{showLoginManagement}}">
              <view class="edit-sub-item" bindtap="onLogout">
                <view class="my-item-icon logout-bg">🚶</view>
                <text class="edit-sub-label">退出登录</text>
                <text class="edit-sub-arrow">›</text>
              </view>
              <view class="edit-sub-item edit-sub-item-last" bindtap="onDeactivateAccount">
                <view class="my-item-icon deactivate-bg">🚪</view>
                <text class="edit-sub-label">注销账号</text>
                <text class="edit-sub-arrow">›</text>
              </view>
            </view>
          </view>
        </view>

      </view>
    </view>

    <!-- 底部占位（防止内容被固定导航遮挡） -->
    <view class="bottom-placeholder"></view>

  </scroll-view>

  <!-- ============================================================
       提醒悬浮入口 + 底部浮层（家庭数据加载完成后显示）
       ============================================================ -->
  <block wx:if="{{!loading && currentFamily}}">

    <!-- 悬浮按钮：有活跃提醒时显示，fixed 定位在底部导航上方 -->
    <view
      class="remind-fab"
      wx:if="{{remindCount > 0}}"
      bindtap="onOpenRemindPanel"
    >
      <text class="remind-fab-icon">📋</text>
      <view class="remind-fab-badge">
        <text class="remind-fab-badge-text">{{remindCount > 99 ? '99+' : remindCount}}</text>
      </view>
    </view>

    <!-- 半透明遮罩：点击关闭浮层 -->
    <view
      class="remind-mask"
      wx:if="{{showRemindPanel}}"
      bindtap="onCloseRemindPanel"
    ></view>

    <!-- 提醒浮层：始终渲染，通过 CSS class 控制滑入/滑出动画 -->
    <view class="remind-panel {{showRemindPanel ? 'remind-panel-show' : ''}}">

      <!-- 顶部拖拽指示条 -->
      <view class="remind-panel-drag-bar"></view>

      <!-- 浮层标题栏 -->
      <view class="remind-panel-header">
        <view class="remind-panel-title-row">
          <text class="remind-panel-header-icon">📋</text>
          <text class="remind-panel-title">即将到来的提醒</text>
          <view class="remind-count-tag" wx:if="{{remindList.length > 0}}">
            <text class="remind-count-tag-text">{{remindList.length}}条</text>
          </view>
        </view>
        <view class="remind-panel-close" bindtap="onCloseRemindPanel">
          <text class="remind-close-text">✕</text>
        </view>
      </view>

      <!-- 加载中状态 -->
      <view class="remind-state-box" wx:if="{{remindLoading}}">
        <view class="remind-loading-spinner"></view>
        <text class="remind-state-text">加载中...</text>
      </view>

      <!-- 空态：暂无待处理提醒 -->
      <view class="remind-state-box" wx:elif="{{!remindLoading && remindList.length === 0}}">
        <text class="remind-state-emoji">🎉</text>
        <text class="remind-state-text">暂无待处理提醒</text>
        <text class="remind-state-sub">所有提醒均已处理完毕</text>
      </view>

      <!-- 提醒列表 -->
      <scroll-view scroll-y class="remind-list-scroll" wx:else>
        <view
          class="remind-item"
          wx:for="{{remindList}}"
          wx:key="remindLogId"
        >
          <!-- 左：分类 emoji 图标 -->
          <view class="remind-item-emoji-wrap">
            <text class="remind-item-emoji">{{item.categoryEmoji}}</text>
          </view>

          <!-- 中：事项信息（标题 + 日期倒计时 + 提前天数） -->
          <view class="remind-item-info">
            <text class="remind-item-title">{{item.title}}</text>
            <text class="remind-item-date {{item.dateClass}}">{{item.dateDesc}}</text>
            <text class="remind-item-advance">{{item.advanceDesc}}</text>
          </view>

          <!-- 右：操作按钮 -->
          <view class="remind-item-actions">
            <view
              class="btn-remind-done"
              bindtap="onRemindDone"
              data-remind-log-id="{{item.remindLogId}}"
              data-index="{{index}}"
            >✓ 完成</view>
            <view
              class="btn-remind-ignore"
              bindtap="onRemindClose"
              data-remind-log-id="{{item.remindLogId}}"
              data-index="{{index}}"
            >× 忽略</view>
          </view>
        </view>
      </scroll-view>

      <!-- 底部安全区（适配 iPhone 刘海屏） -->
      <view class="remind-panel-safe"></view>
    </view>

  </block>

  <!-- 底部固定导航 -->
  <view class="bottom-nav" wx:if="{{!loading && currentFamily}}">
    <view
      class="nav-item {{activeTab === 'home' ? 'nav-active' : ''}}"
      bindtap="switchTab"
      data-tab="home"
    >
      <text class="nav-emoji {{activeTab === 'home' ? 'nav-emoji-active' : ''}}">🏠</text>
      <text class="nav-label">首页</text>
    </view>
    <view
      class="nav-item {{activeTab === 'my' ? 'nav-active' : ''}}"
      bindtap="switchTab"
      data-tab="my"
    >
      <text class="nav-emoji {{activeTab === 'my' ? 'nav-emoji-active' : ''}}">👤</text>
      <text class="nav-label">我的</text>
    </view>
  </view>

</view>
